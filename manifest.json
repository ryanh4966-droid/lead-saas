{
  "manifest_version": 3,
  "name": "Lead SaaS Collector",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
